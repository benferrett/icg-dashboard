# Inner Circle Group Dashboard — environment variables
# Copy to .env locally, or set these in Railway → Variables.

# HubSpot Private App access token (starts with "pat-...").
# Needs scopes: crm.objects.deals.read  (and optionally crm.objects.owners.read
# for live owner names — without it, names fall back to the baked-in map).
HUBSPOT_TOKEN=

# Meta (Facebook) Marketing API access token.
# Generate a long-lived / system-user token so it doesn't expire.
# Needs: ads_read on the ad account(s). Leave blank to hide the Meta section.
META_TOKEN=

# Password users type on the dashboard login screen.
DASHBOARD_PASSWORD=InnerCircle2026$$

# Port the server listens on. Railway sets this automatically; default 5000 locally.
PORT=5000
